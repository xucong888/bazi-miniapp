.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #d4af37;
  border-bottom-color: #d4af37;
  font-weight: bold;
}

.bazi-pillar {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 0;
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  border-radius: 16rpx;
}

.pillar-column {
  text-align: center;
  color: #fff;
}

.pillar-title {
  font-size: 24rpx;
  color: #d4af37;
  margin-bottom: 16rpx;
}

.pillar-gan {
  font-size: 56rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.pillar-zhi {
  font-size: 56rpx;
  font-weight: bold;
  color: #d4af37;
}

.wuxing-list {
  padding: 16rpx 0;
}

.wuxing-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.wuxing-name {
  width: 60rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.wuxing-bar {
  flex: 1;
  height: 24rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  margin: 0 24rpx;
  overflow: hidden;
}

.wuxing-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.3s ease;
}

.wuxing-value {
  width: 100rpx;
  text-align: right;
  font-size: 28rpx;
  color: #666;
}

.daymaster-info {
  text-align: center;
  padding: 24rpx 0;
}

.dm-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #d4af37;
  margin-bottom: 16rpx;
}

.dm-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.xiyong-list {
  padding: 16rpx 0;
}

.xiyong-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.xiyong-item:last-child {
  border-bottom: none;
}

.xiyong-label {
  width: 120rpx;
  font-size: 30rpx;
  color: #666;
}

.xiyong-value {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.ziwei-info, .western-info {
  padding: 16rpx 0;
}

.ziwei-item, .western-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.ziwei-item:last-child, .western-item:last-child {
  border-bottom: none;
}

.ziwei-label, .western-label {
  width: 200rpx;
  font-size: 30rpx;
  color: #666;
}

.ziwei-value, .western-value {
  flex: 1;
  font-size: 30rpx;
  font-weight: bold;
  color: #d4af37;
}

.palace-list {
  padding: 16rpx 0;
}

.palace-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.palace-item:last-child {
  border-bottom: none;
}

.palace-name {
  width: 120rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.palace-ganzhi {
  width: 100rpx;
  font-size: 28rpx;
  color: #666;
}

.palace-stars {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.star-tag {
  background: #d4af37;
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.aspect-list {
  padding: 16rpx 0;
}

.aspect-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.aspect-item:last-child {
  border-bottom: none;
}

.aspect-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.aspect-desc {
  font-size: 26rpx;
  color: #666;
}

.ai-intro {
  padding: 16rpx 0 32rpx;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}