/* 结果页样式 */
.page-wrapper {
  min-height: 100vh;
  background: #faf9f7;
  padding-bottom: 140rpx;
}

/* 结果头部 */
.result-header {
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  padding: 60rpx 40rpx;
  position: relative;
}

.result-header::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: 0;
  right: 0;
  height: 80rpx;
  background: #faf9f7;
  border-radius: 40rpx 40rpx 0 0;
}

.header-content {
  position: relative;
  z-index: 1;
}

.result-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 24rpx;
}

.birth-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.birth-info text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.birth-date {
  color: #d4af37 !important;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  padding: 0 32rpx;
  gap: 16rpx;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-item.active {
  background: #1a1a1a;
  border-color: #d4af37;
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.tab-item text:last-child {
  font-size: 26rpx;
  color: #666;
}

.tab-item.active text:last-child {
  color: #fff;
}

/* 结果内容 */
.result-content {
  padding: 0 32rpx;
}

/* 结果卡片 */
.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  margin-bottom: 32rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  position: relative;
  padding-left: 20rpx;
}

.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: #d4af37;
  border-radius: 3rpx;
}

/* 八字四柱 */
.bazi-pillar {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.pillar-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 16rpx;
  background: #f5f3f0;
  border-radius: 16rpx;
}

.pillar-item.highlight {
  background: #1a1a1a;
}

.pillar-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.pillar-item.highlight .pillar-label {
  color: #d4af37;
}

.pillar-content {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.pillar-gan {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
}

.pillar-item.highlight .pillar-gan {
  color: #fff;
}

.pillar-zhi {
  font-size: 48rpx;
  font-weight: 700;
  color: #d4af37;
}

.pillar-shishen {
  font-size: 22rpx;
  color: #999;
  padding: 4rpx 12rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 8rpx;
}

.pillar-item.highlight .pillar-shishen {
  background: rgba(255, 255, 255, 0.1);
  color: rgba(255, 255, 255, 0.8);
}

/* 五行分析 */
.wuxing-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.wuxing-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.wuxing-name {
  width: 60rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.wuxing-bar {
  flex: 1;
  height: 16rpx;
  background: #f5f3f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.wuxing-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.wuxing-fill.mu { background: #52c41a; }
.wuxing-fill.huo { background: #f5222d; }
.wuxing-fill.tu { background: #faad14; }
.wuxing-fill.jin { background: #fa8c16; }
.wuxing-fill.shui { background: #1890ff; }

.wuxing-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 140rpx;
  justify-content: flex-end;
}

.wuxing-percent {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.wuxing-strength {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx 12rpx;
  background: #f5f3f0;
  border-radius: 8rpx;
}

/* 日主分析 */
.daymaster-section {
  padding: 24rpx 0;
}

.daymaster-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.daymaster-gan {
  width: 100rpx;
  height: 100rpx;
  background: #1a1a1a;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 700;
  color: #d4af37;
}

.daymaster-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.daymaster-element {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.daymaster-strength {
  font-size: 26rpx;
  color: #999;
}

.daymaster-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 喜用神 */
.xiyong-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.xiyong-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f5f3f0;
  border-radius: 16rpx;
}

.xiyong-label {
  font-size: 28rpx;
  color: #666;
}

.xiyong-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #d4af37;
}

.xiyong-value.ji {
  color: #f5222d;
}

/* 紫微斗数 */
.ziwei-info {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #f5f3f0;
  border-radius: 16rpx;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 十二宫位 */
.palace-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.palace-item {
  padding: 24rpx;
  background: #f5f3f0;
  border-radius: 16rpx;
}

.palace-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.palace-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.palace-ganzhi {
  font-size: 26rpx;
  color: #999;
}

.palace-stars {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.star-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #1a1a1a;
  border-radius: 8rpx;
}

.star-tag text:first-child {
  font-size: 26rpx;
  color: #d4af37;
}

.star-brightness {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 西方占星 */
.western-sunsign {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.sunsign-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.sunsign-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
}

.aspect-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.aspect-item {
  padding: 24rpx;
  background: #f5f3f0;
  border-radius: 16rpx;
}

.aspect-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.aspect-desc {
  font-size: 26rpx;
  color: #666;
}

/* MBTI */
.mbti-header {
  text-align: center;
  padding: 40rpx 0;
  background: #1a1a1a;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
}

.mbti-type {
  display: block;
  font-size: 64rpx;
  font-weight: 700;
  color: #d4af37;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.mbti-title {
  font-size: 32rpx;
  color: #fff;
}

.mbti-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: center;
}

.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dimension-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.dimension-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.dimension-bar {
  flex: 1;
  display: flex;
  gap: 12rpx;
}

.dimension-option {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  background: #f5f3f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #999;
  border: 2rpx solid transparent;
}

.dimension-option.active {
  background: rgba(212, 175, 55, 0.1);
  border-color: #d4af37;
  color: #b8941f;
  font-weight: 600;
}

/* 底部操作 */
.result-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 600;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: #1a1a1a;
  color: #fff;
}

.action-btn.secondary {
  background: #f5f3f0;
  color: #333;
}