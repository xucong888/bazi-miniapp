<view class="container">
  <view class="header">
    <text class="title">八字排盘</text>
    <text class="subtitle">探索您的命理奥秘</text>
  </view>

  <view class="card">
    <view class="card-title">基本信息</view>
    
    <view class="input-group">
      <text class="input-label">姓名</text>
      <input class="input-field" placeholder="请输入您的姓名" value="{{birthInfo.name}}" bindinput="onNameInput" />
    </view>

    <view class="input-group">
      <text class="input-label">性别</text>
      <radio-group bindchange="onGenderChange">
        <label class="radio-item"><radio value="male" checked="{{birthInfo.gender === 'male'}}" /><text>男</text></label>
        <label class="radio-item"><radio value="female" checked="{{birthInfo.gender === 'female'}}" /><text>女</text></label>
      </radio-group>
    </view>
  </view>

  <view class="card">
    <view class="card-title">出生时间</view>
    
    <view class="input-group">
      <text class="input-label">历法</text>
      <radio-group bindchange="onCalendarChange">
        <label class="radio-item"><radio value="solar" checked="{{birthInfo.calendarType === 'solar'}}" /><text>公历</text></label>
        <label class="radio-item"><radio value="lunar" checked="{{birthInfo.calendarType === 'lunar'}}" /><text>农历</text></label>
      </radio-group>
    </view>

    <view class="picker-group">
      <view class="picker-item">
        <text class="picker-label">年</text>
        <picker mode="selector" range="{{years}}" value="{{yearIndex}}" bindchange="onYearChange">
          <view class="picker-value">{{years[yearIndex]}}</view>
        </picker>
      </view>
      <view class="picker-item">
        <text class="picker-label">月</text>
        <picker mode="selector" range="{{months}}" value="{{monthIndex}}" bindchange="onMonthChange">
          <view class="picker-value">{{months[monthIndex]}}</view>
        </picker>
      </view>
      <view class="picker-item">
        <text class="picker-label">日</text>
        <picker mode="selector" range="{{days}}" value="{{dayIndex}}" bindchange="onDayChange">
          <view class="picker-value">{{days[dayIndex]}}</view>
        </picker>
      </view>
      <view class="picker-item">
        <text class="picker-label">时</text>
        <picker mode="selector" range="{{hours}}" value="{{hourIndex}}" bindchange="onHourChange">
          <view class="picker-value">{{hours[hourIndex]}}</view>
        </picker>
      </view>
    </view>
  </view>

  <button class="btn-primary" bindtap="calculateFate" loading="{{loading}}" disabled="{{loading}}">
    {{loading ? '排盘中...' : '开始排盘'}}
  </button>

  <view class="tips">
    <text>排盘需要消耗积分，首次使用赠送100积分</text>
  </view>
</view>