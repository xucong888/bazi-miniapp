.header {
  text-align: center;
  padding: 80rpx 0 60rpx;
  background: linear-gradient(180deg, #1a1a1a 0%, #2d2d2d 100%);
  margin: -20rpx -20rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #d4af37;
  margin-bottom: 20rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #ccc;
  letter-spacing: 4rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
  padding-left: 20rpx;
  border-left: 8rpx solid #d4af37;
}

.input-group {
  margin-bottom: 40rpx;
}

.input-group:last-child {
  margin-bottom: 0;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input-field {
  width: 100%;
  height: 96rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  color: #333;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.input-field:focus {
  border-color: #d4af37;
  background: #fff;
}

.radio-group {
  display: flex;
  gap: 48rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 32rpx;
  color: #333;
  padding: 20rpx 32rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  flex: 1;
  justify-content: center;
}

radio {
  transform: scale(0.8);
}

.picker-group {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.picker-item {
  flex: 1;
  min-width: 120rpx;
}

.picker-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.picker-value {
  background: linear-gradient(135deg, #f8f8f8 0%, #f0f0f0 100%);
  padding: 24rpx 20rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #333;
  text-align: center;
  font-weight: 500;
  border: 2rpx solid #e0e0e0;
}

.btn-primary {
  margin-top: 48rpx;
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%);
  color: #fff;
  border-radius: 52rpx;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(212, 175, 55, 0.4);
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  background: #ccc;
  box-shadow: none;
}

.tips {
  text-align: center;
  margin-top: 40rpx;
  padding: 0 40rpx;
}

.tips text {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}