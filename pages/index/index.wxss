/* 页面容器 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a1a 0%, #2d2d2d 300rpx, #f5f5f5 300rpx);
}

/* 顶部背景 */
.header-bg {
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.header-bg::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(circle at 50% 100%, rgba(212, 175, 55, 0.1) 0%, transparent 70%);
}

.header-content {
  position: relative;
  z-index: 1;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 20rpx rgba(212, 175, 55, 0.5);
}

.logo-text {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.app-name {
  font-size: 48rpx;
  font-weight: bold;
  color: #d4af37;
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 4rpx;
}

/* 内容区域 */
.content-wrapper {
  padding: 0 32rpx 60rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

/* 表单卡片 */
.form-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.section-title text {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

/* 表单项 */
.form-item {
  margin-bottom: 40rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 100rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  color: #333;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-input:focus {
  border-color: #d4af37;
  background: #fff;
}

/* 性别选择器 */
.gender-selector {
  display: flex;
  gap: 24rpx;
}

.gender-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.gender-option.active {
  background: rgba(212, 175, 55, 0.1);
  border-color: #d4af37;
}

.gender-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.gender-text {
  font-size: 30rpx;
  color: #333;
}

/* 历法选择器 */
.calendar-selector {
  display: flex;
  gap: 24rpx;
}

.calendar-option {
  flex: 1;
  padding: 28rpx 0;
  text-align: center;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.calendar-option.active {
  background: rgba(212, 175, 55, 0.1);
  border-color: #d4af37;
}

.calendar-option text {
  font-size: 30rpx;
  color: #333;
}

/* 日期选择器 */
.date-picker-group {
  display: flex;
  gap: 16rpx;
}

.date-picker-item {
  flex: 1;
}

.date-picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
}

.date-picker-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.date-picker-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 时间选择器 */
.time-picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
}

.time-picker-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.time-picker-hint {
  font-size: 26rpx;
  color: #999;
}

.time-picker-arrow {
  font-size: 24rpx;
  color: #999;
}

/* 操作区域 */
.action-section {
  padding: 20rpx 0;
}

.submit-btn {
  width: 100%;
  height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%);
  border-radius: 54rpx;
  border: none;
  box-shadow: 0 12rpx 40rpx rgba(212, 175, 55, 0.4);
  transition: all 0.3s;
}

.submit-btn.loading {
  background: #ccc;
  box-shadow: none;
}

.submit-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.btn-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
}

/* 提示区域 */
.tips-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.tips-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #999;
}