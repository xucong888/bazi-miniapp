/* 页面容器 */
.page-wrapper {
  min-height: 100vh;
  background: #faf9f7;
}

/* 头部 */
.page-header {
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  padding: 60rpx 40rpx;
  position: relative;
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: 0;
  right: 0;
  height: 80rpx;
  background: #faf9f7;
  border-radius: 40rpx 40rpx 0 0;
}

.header-content {
  position: relative;
  z-index: 1;
}

.brand {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.brand-icon {
  width: 80rpx;
  height: 80rpx;
  background: rgba(212, 175, 55, 0.2);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: #d4af37;
}

.brand-text {
  display: flex;
  flex-direction: column;
}

.brand-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

.brand-tagline {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

/* 主内容区 */
.main-content {
  padding: 0 32rpx 60rpx;
  position: relative;
  z-index: 1;
  margin-top: -20rpx;
}

/* 卡片区块 */
.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.section-indicator {
  width: 6rpx;
  height: 32rpx;
  background: #d4af37;
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* 表单组 */
.form-group {
  margin-bottom: 40rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.form-control {
  width: 100%;
  height: 96rpx;
  background: #f5f3f0;
  border-radius: 16rpx;
  padding: 0 32rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  border: 2rpx solid transparent;
}

/* 选项组 */
.option-group {
  display: flex;
  gap: 20rpx;
}

.option-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 28rpx 0;
  background: #f5f3f0;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.option-btn.active {
  background: rgba(212, 175, 55, 0.1);
  border-color: #d4af37;
}

.option-icon {
  font-size: 32rpx;
}

.option-text {
  font-size: 30rpx;
  color: #404040;
  font-weight: 500;
}

.option-btn.active .option-text {
  color: #b8941f;
}

/* 选择器行 */
.picker-row {
  display: flex;
  gap: 16rpx;
}

.picker-col {
  flex: 1;
}

.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  background: #f5f3f0;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.picker-box.picker-full {
  width: 100%;
  box-sizing: border-box;
}

.picker-text {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.picker-arrow {
  font-size: 32rpx;
  color: #999;
  transform: rotate(90deg);
}

/* 操作区域 */
.action-area {
  padding: 20rpx 0;
}

.submit-button {
  width: 100%;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #1a1a1a;
  border-radius: 20rpx;
  border: none;
  transition: all 0.2s;
}

.submit-button::after {
  border: none;
}

.submit-button:active {
  background: #2d2d2d;
  transform: scale(0.98);
}

.submit-button.loading {
  background: #999;
}

.btn-icon {
  font-size: 32rpx;
  color: #d4af37;
}

.btn-label {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.helper-text {
  text-align: center;
  margin-top: 32rpx;
}

.helper-text text {
  font-size: 26rpx;
  color: #999;
}