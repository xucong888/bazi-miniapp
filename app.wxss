page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

/* 主题色 */
:root {
  --primary-color: #d4af37;
  --bg-dark: #1a1a1a;
  --bg-light: #f5f5f5;
  --text-primary: #333;
  --text-secondary: #666;
  --text-light: #999;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #d4af37 0%, #b8941f 100%);
  color: #fff;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  border-left: 8rpx solid #d4af37;
  padding-left: 16rpx;
}

/* 输入框样式 */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

/* 排盘结果样式 */
.bazi-pillar {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.pillar-column {
  text-align: center;
  color: #fff;
}

.pillar-title {
  font-size: 24rpx;
  color: #d4af37;
  margin-bottom: 12rpx;
}

.pillar-gan {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.pillar-zhi {
  font-size: 48rpx;
  font-weight: bold;
  color: #d4af37;
}